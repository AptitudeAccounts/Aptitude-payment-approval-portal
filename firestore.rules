rules_version = '2';

// =============================================================================
// Aptitude Payment Approval Portal — Firestore Security Rules
//
// Roles are derived from the signed-in user's email address, matching the
// ROLE_MAP in js/firebase/firebase-config.js:
//   accounts@aptitude.ae     -> Accounts
//   admin@aptitude.ae        -> Administrator
//   operations@aptitude.ae   -> Operations Manager
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth.token.email.lower();
    }

    function isAccounts() {
      return isSignedIn() && email() == 'accounts@aptitude.ae';
    }

    function isAdmin() {
      return isSignedIn() && email() == 'admin@aptitude.ae';
    }

    function isOperations() {
      return isSignedIn() && email() == 'operations@aptitude.ae';
    }

    function isApprover() {
      return isAdmin() || isOperations();
    }

    function isAuthorizedUser() {
      return isAccounts() || isApprover();
    }

    // ---------------------------------------------------------------------
    // payments
    // ---------------------------------------------------------------------
    match /payments/{paymentId} {
      allow read: if isAuthorizedUser() &&
        (isApprover() || resource.data.requestedBy.uid == request.auth.uid);

      // Accounts can create their own requests
      allow create: if isAccounts() &&
        request.resource.data.requestedBy.uid == request.auth.uid &&
        request.resource.data.status in ['Draft', 'Pending Approval'];

      // Accounts can update their OWN request only while it is still a Draft
      // or when submitting it (Draft -> Pending Approval).
      allow update: if isAccounts() &&
        resource.data.requestedBy.uid == request.auth.uid &&
        resource.data.status == 'Draft' &&
        request.resource.data.status in ['Draft', 'Pending Approval'];

      // Admin / Operations can update status, remarks and approval history
      // on any request (approve / reject / hold / mark paid).
      allow update: if isApprover() &&
        request.resource.data.status in
          ['Pending Approval', 'Approved', 'Rejected', 'On Hold', 'Paid'];

      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------------
    // counters (used to generate sequential, human-readable payment IDs)
    // ---------------------------------------------------------------------
    match /counters/{counterId} {
      allow read, write: if isAuthorizedUser();
    }

    // ---------------------------------------------------------------------
    // notifications
    // ---------------------------------------------------------------------
    match /notifications/{notificationId} {
      allow read: if isAuthorizedUser();
      allow create: if isAuthorizedUser();
      allow update: if isAuthorizedUser(); // marking notifications as read
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------------
    // settings (company profile, outlets, categories, payment types)
    // ---------------------------------------------------------------------
    match /settings/{docId} {
      allow read: if isAuthorizedUser();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------
    // suppliers
    // ---------------------------------------------------------------------
    match /suppliers/{supplierId} {
      allow read: if isAuthorizedUser();
      allow write: if isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
